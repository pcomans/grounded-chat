# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# LangSmith — eval harness (scripts/eval) + AI SDK tracing.
# https://docs.langchain.com/langsmith/trace-with-vercel-ai-sdk
# API key: https://smith.langchain.com → Settings → API Keys (also in the Vercel secret manager).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=****
LANGSMITH_PROJECT=grounded-chat
# Defaults to the SaaS endpoint; override for the EU region or self-hosted.
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Optional: override the LLM-as-judge model (Vercel AI Gateway id). Defaults to openai/gpt-oss-120b.
EVAL_JUDGE_MODEL=****
